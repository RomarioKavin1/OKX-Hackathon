# Copy to .env and fill. .env is gitignored.
PRIVATE_KEY=0xYOUR_TESTNET_DEPLOYER_KEY
RPC_URL=https://testrpc.xlayer.tech
CHAIN_ID=1952

# Read layer (Supabase) — service role is SECRET, server-only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Match data
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
# OKX OnchainOS (server-side onchainos CLI auth)
OKX_API_KEY=YOUR_OKX_API_KEY
OKX_SECRET_KEY=YOUR_OKX_SECRET_KEY
OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE
