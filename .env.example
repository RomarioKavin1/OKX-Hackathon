# Copy to .env and fill. .env is gitignored.
PRIVATE_KEY=0xYOUR_TESTNET_DEPLOYER_KEY
RPC_URL=https://testrpc.xlayer.tech
CHAIN_ID=1952

# Optional: multiple signer keys for oracle root submission via publish.ts
# Comma-separated 0x-prefixed private keys. If unset, publish.ts falls back to PRIVATE_KEY.
SIGNER_KEYS=

# Read layer (Supabase) — service role is SECRET, server-only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Match data
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY

# Transparency page — comma-separated list of known oracle signer addresses
# (used to display signer roster + isSigner status on /transparency)
NEXT_PUBLIC_SCORE_ORACLE_SIGNERS=
